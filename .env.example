# Copy this file to .env and fill in your values

# Jira Configuration
JIRA_BASE_URL=https://fundsindia.atlassian.net
JIRA_EMAIL=your_email@fundsindia.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_TICKETS=NOC-21854,NOC-1346,NOC-11734

# Groq LLM - Get free credits at groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=qwen/qwen3-32b
# Batch delay between tickets (seconds). Free tier needs 90s. Paid tier: set to 5.
GROQ_BATCH_DELAY=90

# Database (for production)
DATABASE_URL=postgresql://user:pass@localhost:5432/zero_touch

# Redis (for production)
REDIS_URL=redis://localhost:6379/0

# Monitoring (optional)
LANGSMITH_API_KEY=your_langsmith_key_here

# Environment
ENV=development
DEBUG=true
